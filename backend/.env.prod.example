# ============================================================
# 后端生产环境配置示例
# 使用方式：复制本文件为 backend/.env，并由部署平台或运维系统注入真实值。
# 注意：backend/.env 包含生产密钥和连接信息，禁止提交到 Git。
# ============================================================

# =========================
# 基础服务配置
# =========================

# 应用名称，用于日志、监控和接口文档展示。
APP_NAME=AI 多智能体平台

# 当前运行环境，生产部署必须使用 production。
APP_ENV=production

# 是否开启调试模式，生产环境必须为 false。
DEBUG=false

# 后端服务监听地址，容器部署通常使用 0.0.0.0。
SERVER_HOST=0.0.0.0

# 后端服务监听端口。
SERVER_PORT=8000

# API 版本前缀，用于统一管理后端接口路径。
API_V1_PREFIX=/api/v1

# 允许跨域访问的生产前端地址，多个地址用英文逗号分隔。
CORS_ALLOWED_ORIGINS=https://your-domain.example.com

# =========================
# 安全与认证配置
# =========================

# 后端签名密钥，生产必须使用高强度随机值，并通过密钥管理系统注入。
SECRET_KEY=CHANGE_ME_WITH_STRONG_RANDOM_VALUE

# JWT 访问令牌有效期，单位为分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=60

# JWT 刷新令牌有效期，单位为分钟。
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# 密码哈希算法配置，默认使用 argon2。
PASSWORD_HASH_ALGORITHM=argon2

# =========================
# MySQL 数据库配置
# =========================

# MySQL 生产数据库连接地址，必须使用专用账号和强密码。
DATABASE_URL=mysql+pymysql://ai_agent:${MYSQL_PASSWORD}@mysql:3306/ai_agent_prod?charset=utf8mb4

# 数据库连接池大小，需要根据生产并发和数据库规格调整。
DATABASE_POOL_SIZE=30

# 数据库连接池额外溢出连接数量。
DATABASE_MAX_OVERFLOW=60

# 是否输出 SQL 调试日志，生产环境必须为 false。
DATABASE_ECHO=false

# =========================
# Redis 配置
# =========================

# Redis 生产连接地址，用于缓存、分布式锁、任务状态和事件中转。
REDIS_URL=redis://redis:6379/0

# Redis key 前缀，用于区分生产环境数据。
REDIS_KEY_PREFIX=ai_agent_prod

# =========================
# 异步任务配置
# =========================

# 任务队列 broker 地址，生产环境建议使用独立 Redis DB 或专用队列服务。
CELERY_BROKER_URL=redis://redis:6379/1

# 任务结果存储地址。
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 单个智能体任务默认超时时间，单位为秒。
AGENT_TASK_TIMEOUT_SECONDS=600

# 单个智能体运行最大步骤数，用于防止无限循环和成本失控。
AGENT_MAX_STEPS=30

# =========================
# 大模型与 LangChain 配置
# =========================

# 通用聊天模型名称。生产环境由部署配置决定，例如 gpt-4.1-mini、openai/gpt-4.1-mini 或 deepseek-chat。
LLM_MODEL=openai/gpt-4.1-mini

# 通用大模型 API Key，生产必须通过部署平台密钥系统注入。
LLM_API_KEY=

# 通用大模型接口地址。使用 OpenAI 官方接口时可留空；使用 OpenRouter、DeepSeek、Qwen 等 OpenAI 兼容接口时填写对应 base URL。
LLM_BASE_URL=https://openrouter.ai/api/v1

# 模型回复随机性，数值越低越稳定，生产默认保持适中。
LLM_TEMPERATURE=0.7

# 单次回复最大 token 数，用于控制输出长度和成本。
LLM_MAX_TOKENS=1200

# 大模型请求超时时间，单位为秒。
LLM_TIMEOUT_SECONDS=60

# 大模型请求失败后的最大重试次数，用于应对临时网络错误或限流。
LLM_MAX_RETRIES=3

# =========================
# 向量数据库配置
# =========================

# 向量数据库提供商，生产可使用 qdrant、milvus 或云托管向量库。
VECTOR_STORE_PROVIDER=qdrant

# Qdrant 生产服务地址。
QDRANT_URL=https://qdrant.your-domain.example.com

# Qdrant API Key，生产必须使用真实密钥。
QDRANT_API_KEY=

# Qdrant collection 前缀，用于区分生产数据。
QDRANT_COLLECTION_PREFIX=ai_agent_prod

# Embedding 提供商；生产建议接入稳定的 OpenAI-compatible embedding 服务或自托管 embedding 服务。
EMBEDDING_PROVIDER=openai_compatible

# Embedding 模型名称；切换模型后需要重建对应 collection 的向量。
EMBEDDING_MODEL=text-embedding-3-large

# Embedding 接口地址；若复用默认供应商可留空，否则填写 OpenAI-compatible endpoint。
EMBEDDING_BASE_URL=

# Embedding API Key，生产必须通过密钥系统注入，禁止写入 Git。
EMBEDDING_API_KEY=

# Embedding 向量维度；必须和 Qdrant collection 的 vector size 保持一致。
EMBEDDING_DIMENSION=3072

# RAG 初检召回数量，用于先多召回再去重、过滤和截断。
RAG_TOP_K=20

# RAG 最终注入大模型的知识片段数量，避免把全部检索结果塞进上下文。
RAG_FINAL_TOP_N=5

# RAG 最低相似度阈值，生产需结合真实 embedding 模型和数据集调优。
RAG_SCORE_THRESHOLD=0.35

# RAG 注入大模型的知识上下文最大字符数，用于控制 token 成本和注入风险。
RAG_CONTEXT_MAX_CHARS=3000

# 知识资料 URL 采集请求超时时间，生产建议结合任务队列和重试策略配置。
KNOWLEDGE_COLLECTION_TIMEOUT_SECONDS=15

# 单个网页整理成知识卡片时保留的最大正文字符数，避免抓取页面噪声过大。
KNOWLEDGE_COLLECTION_MAX_CHARS=6000

# 采集整理后的 Markdown 知识卡片沉淀目录；生产如使用容器需挂载持久化卷。
KNOWLEDGE_DOCUMENTS_PATH=/app/knowledge/love_master

# =========================
# 对象存储配置
# =========================

# 文件存储提供商，生产推荐 s3 或 minio。
STORAGE_PROVIDER=s3

# 本地文件存储路径，仅在 STORAGE_PROVIDER=local 时使用。
LOCAL_STORAGE_PATH=/app/storage

# S3 或 MinIO endpoint。
S3_ENDPOINT_URL=https://s3.your-domain.example.com

# S3 或 MinIO bucket 名称。
S3_BUCKET_NAME=ai-agent-prod

# S3 或 MinIO access key，生产必须通过密钥系统注入。
S3_ACCESS_KEY_ID=

# S3 或 MinIO secret key，生产必须通过密钥系统注入。
S3_SECRET_ACCESS_KEY=

# =========================
# 工具与 MCP 配置
# =========================

# 是否启用 MCP 工具接入。
MCP_ENABLED=true

# MCP Server 配置目录，用于加载生产 MCP server 定义。
MCP_SERVER_CONFIG_DIR=/app/config/mcp-servers

# Firecrawl API Key，用于联网搜索、网页抓取和站点爬取。
FIRECRAWL_API_KEY=

# Tavily API Key，用于可选联网搜索工具。
TAVILY_API_KEY=

# Brave Search API Key，用于可选联网搜索工具。
BRAVE_SEARCH_API_KEY=

# 是否启用沙箱工具，例如终端、代码运行和浏览器自动化。
SANDBOX_ENABLED=true

# 沙箱默认运行超时时间，单位为秒。
SANDBOX_TIMEOUT_SECONDS=180

# =========================
# AI 安全拦截配置
# =========================

# 是否启用通用 AI Guardrails，生产环境必须保持开启。
GUARDRAILS_ENABLED=true

# 是否启用 Guardrails 审计记录；生产环境建议开启并接入审计日志。
GUARDRAILS_AUDIT_ENABLED=true

# Guardrails 拦截时返回给用户的默认提示，不能包含内部规则细节。
GUARDRAILS_DEFAULT_BLOCK_MESSAGE=这个请求可能涉及安全或隐私风险，我不能按这个方向继续。

# =========================
# 可观测性配置
# =========================

# 是否启用 OpenTelemetry 链路追踪，生产建议开启。
OTEL_ENABLED=true

# OpenTelemetry collector 地址。
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel.your-domain.example.com

# LangSmith API Key，用于 LangChain 调试、追踪和评测。
LANGSMITH_API_KEY=

# LangSmith 项目名称。
LANGSMITH_PROJECT=ai-agent-prod

# Langfuse 公钥，用于可选 LLM 可观测性。
LANGFUSE_PUBLIC_KEY=

# Langfuse 私钥，用于可选 LLM 可观测性。
LANGFUSE_SECRET_KEY=

# Langfuse 服务地址。
LANGFUSE_HOST=https://langfuse.your-domain.example.com
