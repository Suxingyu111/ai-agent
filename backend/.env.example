# ============================================================
# 后端本地开发环境配置示例
# 使用方式：复制本文件为 backend/.env，并按本机环境修改配置值。
# 注意：backend/.env 包含真实密钥和本地连接信息，禁止提交到 Git。
# ============================================================

# =========================
# 基础服务配置
# =========================

# 应用名称，用于日志、监控和接口文档展示。
APP_NAME=AI 多智能体平台

# 当前运行环境，本地开发固定使用 development。
APP_ENV=development

# 是否开启调试模式，本地开发可设为 true，生产环境必须为 false。
DEBUG=true

# 后端服务监听地址，本地开发通常使用 127.0.0.1。
SERVER_HOST=127.0.0.1

# 后端服务监听端口。
SERVER_PORT=8000

# API 版本前缀，用于统一管理后端接口路径。
API_V1_PREFIX=/api/v1

# 允许跨域访问的前端地址，多个地址用英文逗号分隔。
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:5174,http://localhost:5174

# =========================
# 安全与认证配置
# =========================

# 后端签名密钥，用于 JWT、会话签名等安全场景；本地可使用占位值，生产必须使用强随机值。
SECRET_KEY=dev-change-me

# JWT 访问令牌有效期，单位为分钟。
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# JWT 刷新令牌有效期，单位为分钟。
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# 密码哈希算法配置，默认使用 argon2。
PASSWORD_HASH_ALGORITHM=argon2

# =========================
# MySQL 数据库配置
# =========================

# MySQL 数据库连接地址；本地开发默认使用根目录 docker-compose.yml 暴露的 MySQL 容器，宿主机端口为 3307，避免和本机 MySQL 3306 冲突。
DATABASE_URL=mysql+pymysql://ai_agent:ai_agent_password@127.0.0.1:3307/ai_agent_dev?charset=utf8mb4

# 数据库连接池大小，用于控制常驻连接数量。
DATABASE_POOL_SIZE=10

# 数据库连接池额外溢出连接数量。
DATABASE_MAX_OVERFLOW=20

# 是否输出 SQL 调试日志，本地排查问题时可设为 true。
DATABASE_ECHO=false

# =========================
# Redis 配置
# =========================

# Redis 连接地址；本地开发默认使用根目录 docker-compose.yml 暴露的 Redis 容器。
REDIS_URL=redis://127.0.0.1:6379/0

# Redis key 前缀，用于区分不同项目或环境的数据。
REDIS_KEY_PREFIX=ai_agent_dev

# =========================
# 异步任务配置
# =========================

# 任务队列 broker 地址，默认使用 Redis。
CELERY_BROKER_URL=redis://127.0.0.1:6379/1

# 任务结果存储地址，默认使用 Redis。
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# 单个智能体任务默认超时时间，单位为秒。
AGENT_TASK_TIMEOUT_SECONDS=300

# 单个智能体运行最大步骤数，用于防止无限循环。
AGENT_MAX_STEPS=20

# =========================
# 大模型与 LangChain 配置
# =========================

# 通用聊天模型名称。OpenAI 官方可填写 gpt-4.1-mini；OpenRouter 可填写 openai/gpt-4.1-mini；DeepSeek 可填写 deepseek-chat。
LLM_MODEL=openai/gpt-4.1-mini

# 通用大模型 API Key，本地开发按需填写；不要提交真实值。
LLM_API_KEY=

# 通用大模型接口地址。使用 OpenAI 官方接口时可留空；使用 OpenRouter、DeepSeek、Qwen 等 OpenAI 兼容接口时填写对应 base URL。
LLM_BASE_URL=https://openrouter.ai/api/v1

# 模型回复随机性，数值越低越稳定，恋爱建议类默认保持适中。
LLM_TEMPERATURE=0.7

# 单次回复最大 token 数，用于控制输出长度和成本。
LLM_MAX_TOKENS=1200

# 大模型请求超时时间，单位为秒。
LLM_TIMEOUT_SECONDS=60

# 大模型请求失败后的最大重试次数，用于应对临时网络错误或限流。
LLM_MAX_RETRIES=3

# =========================
# 向量数据库配置
# =========================

# 向量数据库提供商，本地 MVP 推荐 qdrant。
VECTOR_STORE_PROVIDER=qdrant

# Qdrant 服务地址。
QDRANT_URL=http://127.0.0.1:6333

# Qdrant API Key，本地无鉴权时可留空。
QDRANT_API_KEY=

# Qdrant collection 前缀，用于区分不同环境的数据。
QDRANT_COLLECTION_PREFIX=ai_agent_dev

# Embedding 提供商，本地开发默认使用确定性 local_hash，便于无外部密钥时测试 RAG。
EMBEDDING_PROVIDER=local_hash

# Embedding 模型名称；切换模型后需要重建对应 collection 的向量。
EMBEDDING_MODEL=local-hash-v1

# Embedding 接口地址；使用 OpenAI-compatible embedding 服务时填写，本地 local_hash 可留空。
EMBEDDING_BASE_URL=

# Embedding API Key；使用外部 embedding 服务时填写，禁止提交真实密钥。
EMBEDDING_API_KEY=

# Embedding 向量维度；必须和 Qdrant collection 的 vector size 保持一致。
EMBEDDING_DIMENSION=64

# RAG 初检召回数量，用于先多召回再去重、过滤和截断。
RAG_TOP_K=20

# RAG 最终注入大模型的知识片段数量，避免把全部检索结果塞进上下文。
RAG_FINAL_TOP_N=5

# RAG 最低相似度阈值，低于该分数的片段不会进入回答证据。
RAG_SCORE_THRESHOLD=0.1

# RAG 注入大模型的知识上下文最大字符数，用于控制 token 成本和注入风险。
RAG_CONTEXT_MAX_CHARS=3000

# 知识资料 URL 采集请求超时时间，避免外部网页长期无响应阻塞入库。
KNOWLEDGE_COLLECTION_TIMEOUT_SECONDS=15

# 单个网页整理成知识卡片时保留的最大正文字符数，避免抓取页面噪声过大。
KNOWLEDGE_COLLECTION_MAX_CHARS=6000

# 采集整理后的 Markdown 知识卡片沉淀目录；相对路径以 backend/ 为工作目录。
KNOWLEDGE_DOCUMENTS_PATH=./knowledge/love_master

# =========================
# 对象存储配置
# =========================

# 文件存储提供商，本地开发可使用 local，生产推荐 s3 或 minio。
STORAGE_PROVIDER=local

# 本地文件存储路径，用于保存上传文件、运行产物和生成的 PDF。
LOCAL_STORAGE_PATH=./storage

# S3 或 MinIO endpoint，本地使用 local 时可留空。
S3_ENDPOINT_URL=

# S3 或 MinIO bucket 名称，本地使用 local 时可留空。
S3_BUCKET_NAME=

# S3 或 MinIO access key，本地使用 local 时可留空。
S3_ACCESS_KEY_ID=

# S3 或 MinIO secret key，本地使用 local 时可留空。
S3_SECRET_ACCESS_KEY=

# =========================
# 工具与 MCP 配置
# =========================

# 是否启用 MCP 工具接入。
MCP_ENABLED=true

# MCP Server 配置目录，用于加载本地 MCP server 定义。
MCP_SERVER_CONFIG_DIR=./config/mcp-servers

# Firecrawl API Key，用于联网搜索、网页抓取和站点爬取。
FIRECRAWL_API_KEY=

# Tavily API Key，用于可选联网搜索工具。
TAVILY_API_KEY=

# Brave Search API Key，用于可选联网搜索工具。
BRAVE_SEARCH_API_KEY=

# 是否启用沙箱工具，例如终端、代码运行和浏览器自动化。
SANDBOX_ENABLED=true

# 沙箱默认运行超时时间，单位为秒。
SANDBOX_TIMEOUT_SECONDS=120

# =========================
# AI 安全拦截配置
# =========================

# 是否启用通用 AI Guardrails，对所有智能体的用户输入和模型输出进行安全拦截。
GUARDRAILS_ENABLED=true

# 是否启用 Guardrails 审计记录；当前版本保留配置，后续接入审计日志表。
GUARDRAILS_AUDIT_ENABLED=true

# Guardrails 拦截时返回给用户的默认提示，不能包含内部规则细节。
GUARDRAILS_DEFAULT_BLOCK_MESSAGE=这个请求可能涉及安全或隐私风险，我不能按这个方向继续。

# =========================
# 可观测性配置
# =========================

# 是否启用 OpenTelemetry 链路追踪。
OTEL_ENABLED=false

# OpenTelemetry collector 地址。
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318

# LangSmith API Key，用于 LangChain 调试、追踪和评测。
LANGSMITH_API_KEY=

# LangSmith 项目名称。
LANGSMITH_PROJECT=ai-agent-dev

# Langfuse 公钥，用于可选 LLM 可观测性。
LANGFUSE_PUBLIC_KEY=

# Langfuse 私钥，用于可选 LLM 可观测性。
LANGFUSE_SECRET_KEY=

# Langfuse 服务地址。
LANGFUSE_HOST=
