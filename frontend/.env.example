# ============================================================
# 前端本地开发环境配置示例
# 使用方式：复制本文件为 frontend/.env，并按本机环境修改配置值。
# 注意：frontend/.env 包含本地服务地址或公开配置，禁止提交到 Git。
# Vite 只会向浏览器暴露 VITE_ 前缀的变量。
# ============================================================

# =========================
# 基础应用配置
# =========================

# 前端应用名称，用于浏览器标题、导航和页面展示。
VITE_APP_NAME=AI 多智能体平台

# 当前前端运行环境，本地开发固定使用 development。
VITE_APP_ENV=development

# 默认语言配置。
VITE_DEFAULT_LOCALE=zh-CN

# =========================
# 后端接口配置
# =========================

# 后端 API 基础地址，本地开发指向 FastAPI 服务。
VITE_API_BASE_URL=http://127.0.0.1:8000/api/v1

# 后端请求超时时间，单位为毫秒。
VITE_API_TIMEOUT_MS=30000

# SSE 事件流基础地址，用于订阅智能体运行事件。
VITE_SSE_BASE_URL=http://127.0.0.1:8000/api/v1

# WebSocket 基础地址，用于未来实时协作或长连接能力。
VITE_WS_BASE_URL=ws://127.0.0.1:8000/api/v1

# =========================
# 功能开关配置
# =========================

# 是否启用本地 mock 数据，本地开发可按需开启。
VITE_ENABLE_MOCK=false

# 是否启用智能体构建器页面。
VITE_ENABLE_AGENT_BUILDER=true

# 是否启用 Workflow 可视化编排页面。
VITE_ENABLE_WORKFLOW_BUILDER=true

# 是否启用 MCP 工具市场页面。
VITE_ENABLE_MCP_MARKETPLACE=true

# 是否启用前端调试面板，本地开发可开启，生产环境必须关闭。
VITE_ENABLE_DEBUG_PANEL=true

# =========================
# 静态资源和产物配置
# =========================

# 公开文件访问基础地址，用于展示上传文件、任务产物和生成的 PDF。
VITE_PUBLIC_STORAGE_BASE_URL=http://127.0.0.1:8000/api/v1/artifacts

# =========================
# 可观测性配置
# =========================

# Sentry DSN，用于前端错误上报；本地开发可留空。
VITE_SENTRY_DSN=

# 前端 OpenTelemetry collector 地址；未启用时可留空。
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=
