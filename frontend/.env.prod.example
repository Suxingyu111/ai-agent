# ============================================================
# 前端生产环境配置示例
# 使用方式：复制本文件为 frontend/.env，并由部署平台注入生产值。
# 注意：frontend/.env 禁止提交到 Git。
# Vite 只会向浏览器暴露 VITE_ 前缀的变量，不能放任何私密密钥。
# ============================================================

# =========================
# 基础应用配置
# =========================

# 前端应用名称，用于浏览器标题、导航和页面展示。
VITE_APP_NAME=AI 多智能体平台

# 当前前端运行环境，生产部署必须使用 production。
VITE_APP_ENV=production

# 默认语言配置。
VITE_DEFAULT_LOCALE=zh-CN

# =========================
# 后端接口配置
# =========================

# 后端 API 基础地址，生产环境指向线上 API 网关。
VITE_API_BASE_URL=https://api.your-domain.example.com/api/v1

# 后端请求超时时间，单位为毫秒。
VITE_API_TIMEOUT_MS=30000

# SSE 事件流基础地址，用于订阅智能体运行事件。
VITE_SSE_BASE_URL=https://api.your-domain.example.com/api/v1

# WebSocket 基础地址，用于未来实时协作或长连接能力。
VITE_WS_BASE_URL=wss://api.your-domain.example.com/api/v1

# =========================
# 功能开关配置
# =========================

# 是否启用本地 mock 数据，生产环境必须关闭。
VITE_ENABLE_MOCK=false

# 是否启用智能体构建器页面。
VITE_ENABLE_AGENT_BUILDER=true

# 是否启用 Workflow 可视化编排页面。
VITE_ENABLE_WORKFLOW_BUILDER=true

# 是否启用 MCP 工具市场页面。
VITE_ENABLE_MCP_MARKETPLACE=true

# 是否启用前端调试面板，生产环境必须关闭。
VITE_ENABLE_DEBUG_PANEL=false

# =========================
# 静态资源和产物配置
# =========================

# 公开文件访问基础地址，用于展示上传文件、任务产物和生成的 PDF。
VITE_PUBLIC_STORAGE_BASE_URL=https://api.your-domain.example.com/api/v1/artifacts

# =========================
# 可观测性配置
# =========================

# Sentry DSN，用于前端错误上报；生产环境建议配置。
VITE_SENTRY_DSN=

# 前端 OpenTelemetry collector 地址；未启用时可留空。
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=
